# ======================
# PROJECT-SPECIFIC
# ======================

# --- Raw dataset (1.7 GB — never commit this) ---
artifacts/raw/
*.h5
*.npz
*.zip

# --- Trained models (can be large, regenerate from train_pipeline.py) ---
artifacts/models/
*.pkl
*.joblib

# --- Logs ---
artifacts/logs/
*.log

# --- Processed arrays saved during transformation ---
# (regenerable — no need to track in git)
artifacts/snr.npy
artifacts/poi_idx_snr.npy
artifacts/poi_idx_anova.pkl
artifacts/pca.pkl
artifacts/profiling.npz
artifacts/attack.npz

# --- Plots and figures saved to disk ---
# Keep the notebooks that generate them; ignore the saved image files
artifacts/*.png
artifacts/*.pdf
artifacts/*.svg

# Ingested arrays
artifacts/ingested/
artifacts/transformed/

# Processed dataset
artifacts/raw/ASCAD_processed.h5
artifacts/raw/*.png

# --- MLflow experiment tracking ---
mlruns/
mlflow.db

# --- Notebook output caches ---
# (outputs are reproducible; don't bloat git history with embedded plots)
notebooks/.ipynb_checkpoints/

