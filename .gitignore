# Transformed arrays (regenerated by data_transformation.py)
artifacts/transformed/

# Saved models (regenerated by model_trainer.py)
artifacts/models/*.joblib
artifacts/models/*.pkl

# Plots (regenerated by notebooks)
artifacts/raw/*.png

# Logs
